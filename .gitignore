# =============================================================================
# .gitignore — Projeto Python (Pygame + Pytest)
# =============================================================================

# -----------------------------------------------------------------------------
# Ambientes Virtuais
# -----------------------------------------------------------------------------
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# Cache do Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# -----------------------------------------------------------------------------
# Ferramentas de Teste e Cobertura
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
*.log
nosetests.xml
junit.xml

# -----------------------------------------------------------------------------
# Arquivos de Distribuição / Build
# -----------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
MANIFEST
wheels/
pip-wheel-metadata/
share/python-wheels/

# -----------------------------------------------------------------------------
# Arquivos de Sistema Operacional
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# -----------------------------------------------------------------------------
# Arquivos de IDEs e Editores
# -----------------------------------------------------------------------------
# VS Code
.vscode/

# JetBrains (PyCharm, IDEA, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# -----------------------------------------------------------------------------
# Variáveis de Ambiente e Segredos
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Pygame / Assets gerados em runtime
# -----------------------------------------------------------------------------
*.log
screenshots/

# -----------------------------------------------------------------------------
# Mypy / Type Checkers
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
